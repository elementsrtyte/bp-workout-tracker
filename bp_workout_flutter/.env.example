# Blueprint Workout — Flutter
#
# Local secrets (gitignored), used by the app on device/simulator:
#   cp .env.example .env.local
#   # edit .env.local — it is listed in pubspec.yaml assets so iOS/Android can read it
#     (the running app’s current working directory is not your project folder).
#
# Precedence (highest first):
#   1) --dart-define=KEY=value  (or --dart-define-from-file=...)
#   2) Exported shell variables (Platform.environment)
#   3) `.env` then `.env.local` on disk (dev / desktop; monorepo paths searched)
#   4) Bundled `.env.local` on iOS/Android only (merged after disk)
#   5) This file (`.env.example`)

SUPABASE_URL=
SUPABASE_ANON_KEY=
BLUEPRINT_API_URL=
