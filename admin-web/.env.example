# Copy to .env.local (gitignored). Same Supabase project as the mobile app; anon key only.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Blueprint API (local or Railway) — must expose /v1/admin/* with ADMIN_EMAILS configured.
VITE_BLUEPRINT_API_URL=http://127.0.0.1:8787
