# Copy to .env and fill in. Names must match exactly unless you use the lowercase aliases below.
OPENAI_API_KEY=
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=

# Server-only: required for POST /v1/admin/publish-catalog-program (dev catalog edits).
# Never expose this key in the iOS app or public repos.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated Supabase auth emails allowed to publish catalog programs (dev tool).
# Example: CATALOG_ADMIN_EMAILS=you@example.com
CATALOG_ADMIN_EMAILS=neil@blueprintapps.io

PORT=8787
