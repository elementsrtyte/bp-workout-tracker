# Copy to .env and/or .env.local and fill in. The server loads .env then overrides from .env.local (gitignored).
# Hosted: SUPABASE_URL=https://<project-ref>.supabase.co (see `supabase projects list` / Dashboard). Local CLI: http://127.0.0.1:54321
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only: required for POST /v1/admin/catalog/programs (dev catalog edits).
# Never expose this key in the iOS app or public repos.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated Supabase auth emails allowed for /v1/admin/* (catalog publish, seed edits, workout cleanup).
# Merged with CATALOG_ADMIN_EMAIL* if you still use those names.
# Example: ADMIN_EMAILS=you@example.com
ADMIN_EMAILS=
CATALOG_ADMIN_EMAILS=neil@blueprintapps.io

PORT=8787
